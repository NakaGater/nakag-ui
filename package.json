{
  "name": "@nakagater/ui",
  "version": "0.1.0",
  "description": "Personal design system: shadcn/ui-based React components + framework-free slide CSS",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nakagater/nakag-ui.git"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./theme.css": "./dist/theme.css",
    "./slides/slide.css": "./dist/slides/slide.css",
    "./slides/template.html": "./dist/slides/template.html",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown && node scripts/build-css.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check:pkg": "publint && attw --pack . --profile esm-only --entrypoints ."
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "^2.5.4",
    "@storybook/addon-themes": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.0",
    "tailwindcss": "^4.3.2",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
